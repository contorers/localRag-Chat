{
  "name": "project-one-localrag",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "tauri:build": "tauri build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.cipherwhisper.localrag",
    "productName": "LocalRAG-Chat",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "LocalRAG",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@vueuse/core": "^14.3.0",
    "@xenova/transformers": "^2.17.2",
    "dexie": "^4.4.2",
    "dompurify": "^3.4.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "katex": "^0.16.45",
    "lodash-es": "^4.18.1",
    "markdown-it": "^14.1.1",
    "markdown-it-for-inline": "^2.0.1",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.14.0",
    "minisearch": "^7.2.0",
    "pinia": "^3.0.4",
    "plantuml-encoder": "^1.4.0",
    "somarkdown": "^1.2.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
